# Copy to .env.local for local dev. On Vercel: Project Settings → Environment Variables.

# Core
MONGODB_URI=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Demo deploy (Vercel) — no real card charges; set both to true
NEXORA_DEMO_MODE=true
NEXT_PUBLIC_NEXORA_DEMO_MODE=true

# Local dev only (ignored when NEXORA_DEMO_MODE=true on server)
ALLOW_DEV_PAYMENT_BYPASS=true

# Stripe — optional if NEXORA_DEMO_MODE=true
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AI (optional; chat/search need login)
GROQ_API_KEY=

# Media (admin product upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed (run locally: npm run seed:secrets && npm run seed)
SEED_SECRET=
SEED_ADMIN_EMAIL=admin@nexora.com
SEED_ADMIN_PASSWORD=
SEED_USER_EMAIL=test@nexora.com
SEED_USER_PASSWORD=

# Production rate limits (recommended on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRUST_PROXY=true
